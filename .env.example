# ──────────────────────────────────────────────────────────────────────────────
# DAGRD API — Application settings
# Copy this file to .env and customise before running docker compose up
# ──────────────────────────────────────────────────────────────────────────────

# ── FastAPI ──────────────────────────────────────────────────────────────────
APP_NAME="DAGRD API"
APP_VERSION="1.0.0"
DEBUG=false

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=dagrd_db
# Override only when running outside Docker (e.g. locally):
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dagrd_db

# ── JWT ──────────────────────────────────────────────────────────────────────
# IMPORTANT: replace with a long random string in production!
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=supersecretkey-change-me-in-production-please
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
